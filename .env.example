# Redis
REDIS_URL=redis://localhost:6379

# DynamoDB Local
DYNAMODB_ENDPOINT=http://localhost:8001
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Bedrock (Phase 4)
# Set BEDROCK_MODE=real once you have real AWS creds + model access.
# In mock mode, no AWS connection is made — embeddings/generations are
# deterministic stubs.
BEDROCK_MODE=mock
BEDROCK_REGION=us-east-1
BEDROCK_TEXT_MODEL=anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

# OpenSearch (Phase 7+)
# OPENSEARCH_ENDPOINT=http://localhost:9200

# S3 traces (Phase 9+)
# S3_TRACES_BUCKET=hyperpersona-traces

# API auth (Phase 8+)
# API_KEY=test-key
